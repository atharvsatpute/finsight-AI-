# API Keys
GROQ_API_KEY=your_groq_api_key
HUGGINGFACE_API_KEY=your_hf_api_key
NEWS_API_KEY=your_newsapi_key
SEC_API_KEY=your_sec_api_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# AWS
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-west-2
S3_BUCKET=finsight-ai-prod

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_NEWS=finsight.news
KAFKA_TOPIC_PRICES=finsight.prices
KAFKA_TOPIC_FILINGS=finsight.filings

# Database
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://postgres:password@localhost:5432/finsight

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=finsight-rag

# App
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
