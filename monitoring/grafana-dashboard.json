{
  "annotations": { "list": [] },
  "title": "FinSight AI — Production Dashboard",
  "uid": "finsight-prod",
  "panels": [
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(finsight_requests_total[5m])",
        "legendFormat": "req/s"
      }]
    },
    {
      "title": "Agent Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "expr": "rate(finsight_agent_runs_total{status='success'}[5m]) / rate(finsight_agent_runs_total[5m]) * 100",
        "legendFormat": "success %"
      }]
    },
    {
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(finsight_request_latency_seconds_bucket[5m]))",
        "legendFormat": "p99 seconds"
      }]
    },
    {
      "title": "Total Vectors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "expr": "finsight_total_vectors",
        "legendFormat": "vectors"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {}
}
